<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentFold.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FluentFold">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="FluentFold">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            CompactPaneLength="48"
            AlwaysShowHeader="False"
            ItemInvoked="OnItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="OrgItem" Content="Organizer" Tag="organizer">
                    <NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedFindVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Folder" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="HistItem" Content="History" Tag="history">
                    <NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedBackVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Undo" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AnalItem" Content="Analyzer" Tag="analyzer">
                    <NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedFindVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Find" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettItem" Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedSettingsVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Setting" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AboutItem" Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedGlobalNavigationButtonVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Help" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- ===== ONBOARDING OVERLAY ===== -->
        <Grid
            x:Name="OnboardingOverlayElement"
            Grid.RowSpan="2"
            Visibility="Collapsed"
            Background="{ThemeResource SolidBackgroundFillColorBase}">

            <!-- Floating card -->
            <Border
                x:Name="OnboardingCardRoot"
                Width="580" MinWidth="400" MaxWidth="700"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefault}"
                BorderBrush="{ThemeResource CardStrokeColorDefault}"
                BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header with X Close + Skip -->
                    <Grid Grid.Row="0" Margin="16,12,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Quick Tour" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="SkipButton" Grid.Column="1"
                                Content="Skip" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{ThemeResource SystemAccentColor}"
                                Padding="8,4"
                                Click="OnSkipClick" />
                        <Button x:Name="CloseButton" Grid.Column="2"
                                Content="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="14" Width="32" Height="32" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Click="OnCloseClick" />
                    </Grid>

                    <!-- Slide Content -->
                    <Grid x:Name="ContentRoot" Grid.Row="1" Padding="24,16">
                        <Grid.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromHorizontalOffset="60" />
                            </TransitionCollection>
                        </Grid.ChildrenTransitions>

                        <!-- Slide 0: Welcome -->
                        <StackPanel x:Name="Slide0" Visibility="Visible" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                       FontSize="64" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Welcome to FluentFold" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="The modern file organization tool for Windows 11"
                                           FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                            <Border CornerRadius="12" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefault}" MaxWidth="400">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Get started in seconds:" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="&#x2713;  Auto-categorize your files by type" FontSize="13" />
                                    <TextBlock Text="&#x2713;  Scan and analyze folder contents" FontSize="13" />
                                    <TextBlock Text="&#x2713;  Find and remove duplicates" FontSize="13" />
                                    <TextBlock Text="&#x2713;  Custom rules for advanced control" FontSize="13" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Slide 1: Smart Organization -->
                        <StackPanel x:Name="Slide1" Visibility="Collapsed" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE768;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                       FontSize="56" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Smart Organization" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Sort, categorize, and rename files with ease"
                                           FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                            <Grid MaxWidth="420" ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE943;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Auto-categorize" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Files sorted into Images, Docs, Videos &amp; more" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE8AC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Bulk Rename" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Pattern-based renaming with previews" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE943;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Custom Rules" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Extension + trigger-based categorization" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE7A7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="One-click Undo" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Revert any organization instantly" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Slide 2: Storage Analysis -->
                        <StackPanel x:Name="Slide2" Visibility="Collapsed" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE774;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                       FontSize="56" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Storage Analysis" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Deep scan and reclaim disk space"
                                           FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                            <Grid MaxWidth="420" ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE896;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Temp Files" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Scan system &amp; app temporary files" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE8A6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Duplicates" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Byte-level duplicate detection" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE81C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Large Files" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Find files over 100 MB instantly" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefault}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="&#xE7FC;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="Safe Cleanup" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="Secure deletion with Recycle Bin" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Slide 3: Ready -->
                        <StackPanel x:Name="Slide3" Visibility="Collapsed" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                       FontSize="64" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="You're all set!" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Select a folder to get started, or explore the Analyzer for a deep dive."
                                           FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360" />
                            </StackPanel>
                            <Border CornerRadius="12" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefault}" MaxWidth="400">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="&#xE838;  Pick any folder to organize" FontSize="13" />
                                    <TextBlock Text="&#xE8A5;  Use the Analyzer tab for storage insights" FontSize="13" />
                                    <TextBlock Text="&#xE943;  Switch to Pro mode for advanced controls" FontSize="13" />
                                    <TextBlock Text="&#xE772;  Visit Settings to customize your experience" FontSize="13" />
                                </StackPanel>
                            </Border>
                            <StackPanel Spacing="4" HorizontalAlignment="Center" MaxWidth="400">
                                <ToggleSwitch x:Name="PinToStartToggle" Header="Pin to Start menu" IsOn="True" />
                                <ToggleSwitch x:Name="PinToTaskbarToggle" Header="Pin to taskbar" IsOn="True" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Bottom Navigation -->
                    <Border Grid.Row="2" Margin="24,0,24,20" Padding="16,8" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefault}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BackButton" Grid.Column="0"
                                    Content="&#xE76B;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16" Width="40" Height="40" CornerRadius="8"
                                    Click="OnBackClick" ToolTipService.ToolTip="Back" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                <Ellipse x:Name="Dot0" Width="10" Height="10" Fill="{ThemeResource SystemAccentColor}" />
                                <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                                <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                                <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>

                            <Button x:Name="NextButton" Grid.Column="2"
                                    Content="&#xE76C;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16" Width="40" Height="40" CornerRadius="8"
                                    Click="OnNextClick" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
