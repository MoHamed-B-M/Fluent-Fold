<Page
    x:Class="FluentFold.Views.AnalyzerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FluentFold.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="24">

                <TextBlock Text="Analyzer" Style="{StaticResource TitleTextBlockStyle}" />

                <!-- ===== IDLE STATE ===== -->
                <StackPanel
                    Visibility="{x:Bind ViewModel.IdleVisibility, Mode=OneWay}"
                    HorizontalAlignment="Center" Spacing="24" Margin="0,40">

                    <Grid Width="200" Height="200" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlowEllipse"
                            Width="200" Height="200"
                            Fill="{ThemeResource SystemAccentColor}"
                            Opacity="0.12"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Button
                            Command="{x:Bind ViewModel.StartScanCommand}"
                            Width="160" Height="160"
                            CornerRadius="80"
                            Background="{ThemeResource SystemAccentColor}"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            PointerEntered="ScanButton_PointerEntered"
                            PointerExited="ScanButton_PointerExited"
                            PointerPressed="ScanButton_PointerPressed"
                            PointerReleased="ScanButton_PointerReleased">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8D3;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                           FontSize="40" HorizontalAlignment="Center" />
                                <TextBlock Text="Analyze" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="Scan system for junk files, cache, and duplicates"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" FontSize="14" />
                    <TextBlock Text="Click the button above to start"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- ===== SCANNING STATE ===== -->
                <Border
                    Visibility="{x:Bind ViewModel.ScanningVisibility, Mode=OneWay}"
                    Style="{StaticResource FluentCardStyle}"
                    HorizontalAlignment="Center"
                    MinWidth="360">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" />
                        <ProgressBar
                            Value="{x:Bind ViewModel.ScanProgress, Mode=OneWay}"
                            IsIndeterminate="False"
                            Width="280" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center" />
                        <Button Command="{x:Bind ViewModel.CancelScanCommand}"
                                Content="&#xE10A;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                HorizontalAlignment="Center"
                                Width="36" Height="36"
                                ToolTipService.ToolTip="Cancel" />
                    </StackPanel>
                </Border>

                <!-- ===== RESULTS STATE (Dashboard) ===== -->
                <StackPanel
                    Visibility="{x:Bind ViewModel.ResultsVisibility, Mode=OneWay}"
                    Spacing="20">

                    <!-- Summary Header Card -->
                    <Border Style="{StaticResource FluentCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Storage Analysis" FontSize="20" FontWeight="Bold" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14">
                                    <Run Text="Found " />
                                    <Run Text="{x:Bind ViewModel.TotalItems, Mode=OneWay}" FontWeight="Bold" />
                                    <Run Text=" items taking " />
                                    <Run Text="{x:Bind ViewModel.TotalReclaimable, Mode=OneWay}" FontWeight="Bold" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Command="{x:Bind ViewModel.SelectAllCommand}" Content="Select All" />
                                <Button Command="{x:Bind ViewModel.DeselectAllCommand}" Content="Deselect All" />
                                <Button Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        IsEnabled="{x:Bind ViewModel.IsNotDeleting, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                        <TextBlock Text="Delete" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Dashboard Cards Grid -->
                    <ItemsRepeater
                        ItemsSource="{x:Bind ViewModel.DashboardCards, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinColumnSpacing="16"
                                MinRowSpacing="16"
                                MinItemWidth="320" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:DashboardCard">
                                <Border Style="{StaticResource DashboardCardStyle}">
                                    <StackPanel Spacing="12">
                                        <!-- Header Row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Icon}"
                                                       FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                       FontSize="32"
                                                       Foreground="{ThemeResource SystemAccentColor}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="16" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12">
                                                    <Run Text="{x:Bind Count}" />
                                                    <Run Text=" items" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Content Row -->
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <ProgressBar
                                                    Value="{x:Bind Percent, Mode=OneWay}"
                                                    IsIndeterminate="False"
                                                    Height="6"
                                                    CornerRadius="3" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind SizeFormatted}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- Expandable Details -->
                                        <controls:Expander
                                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch">
                                            <controls:Expander.Header>
                                                <TextBlock Text="Show details" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </controls:Expander.Header>
                                            <ListView
                                                ItemsSource="{x:Bind Items}"
                                                SelectionMode="None"
                                                MaxHeight="240">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:AnalyzerItem">
                                                        <Grid Padding="8,4" ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="100" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                      VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </controls:Expander>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
