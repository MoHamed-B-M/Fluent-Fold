<ContentDialog
    x:Class="FluentFold.Views.CleanupReviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:FluentFold.Models"
    Title="Review Files for Cleanup"
    PrimaryButtonText="Delete Selected"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Width="600"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <StackPanel Spacing="12">
        <TextBlock Text="The following files may be safely removed:"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <ListView
            ItemsSource="{x:Bind ViewModel.CleanupFiles, Mode=OneWay}"
            SelectionMode="None"
            MaxHeight="400">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CleanupFileItem">
                    <Grid Padding="8,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="3" Text="{x:Bind Reason}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
