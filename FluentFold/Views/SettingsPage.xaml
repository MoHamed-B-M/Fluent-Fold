<Page
    x:Class="FluentFold.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentFold.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24,16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="600">
                <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Customize application behavior" FontSize="14" Opacity="0.6" Margin="0,-12,0,0" />

                <!-- Theme Card -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Dark Theme" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.ThemeLabel, Mode=OneWay}"
                                    FontSize="12"
                                    Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch
                                Grid.Column="1"
                                IsOn="{x:Bind ViewModel.IsDarkTheme, Mode=TwoWay}"
                                OnContent="Dark"
                                OffContent="Light" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- About Card -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="About" FontSize="16" FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Fluent Fold" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="Version 1.0.0" FontSize="13" Opacity="0.6" />
                            <TextBlock
                                Text="Organize and rename files in bulk with Windows 11 Fluent Design."
                                FontSize="13"
                                Opacity="0.6"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock
                            Text="Built with WinUI 3, CommunityToolkit.Mvvm, and Windows App SDK"
                            FontSize="12"
                            Opacity="0.4"
                            Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Categories Card -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="File Categories" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock
                            Text="Files are organized into these categories based on their extension:"
                            FontSize="13"
                            Opacity="0.6"
                            TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*" RowSpacing="8" ColumnSpacing="16">
                            <StackPanel>
                                <TextBlock Text="Images" FontWeight="SemiBold" />
                                <TextBlock Text=".jpg, .jpeg, .png, .gif, .bmp, .svg, .ico, .webp" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Documents" FontWeight="SemiBold" />
                                <TextBlock Text=".pdf, .doc, .docx, .txt, .xls, .xlsx, .ppt, .pptx, .md, .csv, .json, .xml, .html, .css, .js" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="Videos" FontWeight="SemiBold" />
                                <TextBlock Text=".mp4, .avi, .mkv, .mov, .wmv, .flv, .webm" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Audio" FontWeight="SemiBold" />
                                <TextBlock Text=".mp3, .wav, .flac, .aac, .ogg, .m4a" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Archives" FontWeight="SemiBold" />
                                <TextBlock Text=".zip, .rar, .7z, .tar, .gz, .bz2, .iso" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Code" FontWeight="SemiBold" />
                                <TextBlock Text=".py, .java, .cpp, .c, .js, .ts, .go, .rs, .rb, .php, .sql, .sh, .bat, .ps1" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
                                <TextBlock Text="Others" FontWeight="SemiBold" />
                                <TextBlock Text="Any extension not listed above" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock
                    Text="Made with ❤️ for Windows 11"
                    FontSize="12"
                    Opacity="0.4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
