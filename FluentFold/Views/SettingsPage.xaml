<Page
    x:Class="FluentFold.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,16,32,16">
        <StackPanel Spacing="12">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <ToggleSwitch x:Name="ThemeToggle" Header="Dark Theme" Toggled="OnThemeToggled" />

            <TextBlock Text="Fluent Fold v1.0" Style="{StaticResource BodyTextBlockStyle}" />
            <TextBlock Text="Organize your files with ease." Style="{StaticResource BodyTextBlockStyle}" />
        </StackPanel>
    </Grid>
</Page>