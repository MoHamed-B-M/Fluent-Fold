<Page
    x:Class="FluentFold.Views.OrganizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Grid Margin="32,16,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="12">
            <TextBlock Text="Folder Organizer" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Select a folder to analyze and organize your files." Style="{StaticResource BodyTextBlockStyle}" />

            <Button x:Name="PickFolderButton" Content="Pick Folder" Click="OnPickFolder" Style="{StaticResource AccentButtonStyle}" />

            <TextBlock x:Name="FolderPathText" Style="{StaticResource BodyTextBlockStyle}" />

            <controls:InfoBar
                x:Name="InfoBarControl"
                IsClosable="True" />

            <controls:ProgressRing
                x:Name="ProgressControl"
                IsActive="False"
                Visibility="Collapsed" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0">
            <StackPanel x:Name="OptionsPanel" Spacing="12" Visibility="Collapsed">
                <TextBlock Text="Options" Style="{StaticResource SubtitleTextBlockStyle}" />

                <ToggleSwitch x:Name="OrganizeToggle" Header="Organize into category folders" IsOn="True" />
                <ToggleSwitch x:Name="RenameToggle" Header="Rename files with pattern" Toggled="OnRenameToggled" />

                <TextBox
                    x:Name="PatternBox"
                    Header="Rename pattern"
                    PlaceholderText="e.g. MyFile"
                    IsEnabled="False" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Organize" x:Name="OrganizeButton" Click="OnOrganize" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Undo" x:Name="UndoButton" Click="OnUndo" IsEnabled="False" />
                </StackPanel>

                <TextBlock x:Name="SummaryHeader" Text="Folder Summary" Style="{StaticResource SubtitleTextBlockStyle}" Visibility="Collapsed" />

                <ItemsControl x:Name="CategoryList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding CategoryName}" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Count}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>