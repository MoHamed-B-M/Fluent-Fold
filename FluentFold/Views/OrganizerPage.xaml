<Page
    x:Class="FluentFold.Views.OrganizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentFold.ViewModels"
    xmlns:controls="using:FluentFold.Views"
    Loaded="OnLoaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:Key="CategoryCardTemplate" x:DataType="local:CategoryCountItem">
            <Border
                Background="{ThemeResource CardBackgroundBrush}"
                CornerRadius="8"
                Padding="16,12"
                MinWidth="140">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <TextBlock
                        Text="{x:Bind Icon}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="28"
                        Foreground="{x:Bind ColorCode}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind Count}"
                        FontSize="24"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0" />
                    <TextBlock
                        Grid.Row="2"
                        Text="{x:Bind CategoryName}"
                        FontSize="13"
                        Opacity="0.7"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="NotificationBar"
            Title="{x:Bind ViewModel.NotificationTitle, Mode=OneWay}"
            Message="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
            Severity="{x:Bind ViewModel.NotificationSeverity, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.IsNotificationOpen, Mode=TwoWay}"
            IsClosable="True"
            Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <!-- Header Section -->
                <TextBlock Text="Fluent Fold" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Organize and rename files in bulk" FontSize="14" Opacity="0.6" Margin="0,-12,0,0" />

                <!-- Folder Selection -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Folder" FontSize="16" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <TextBox
                                Text="{x:Bind ViewModel.FolderPath, Mode=OneWay}"
                                PlaceholderText="Select a folder to organize..."
                                IsReadOnly="True"
                                IsTabStop="False" />
                            <Button
                                Grid.Column="1"
                                Content="Browse"
                                Command="{x:Bind ViewModel.BrowseFolderCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                Grid.Column="2"
                                Content="Refresh"
                                Command="{x:Bind ViewModel.RefreshSummaryCommand}"
                                IsEnabled="{x:Bind ViewModel.IsFolderSelected, Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Summary Section -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Summary" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                FontSize="12"
                                Opacity="0.6"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="16">
                            <Border
                                Background="{ThemeResource SummaryCardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12"
                                MinWidth="120">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.TotalFiles, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" />
                                    <TextBlock Text="Files" FontSize="13" Opacity="0.7" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Background="{ThemeResource SummaryCardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12"
                                MinWidth="120">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.TotalFolders, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" />
                                    <TextBlock Text="Folders" FontSize="13" Opacity="0.7" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ItemsRepeater
                            ItemsSource="{x:Bind ViewModel.CategoryCounts, Mode=OneWay}"
                            ItemTemplate="{StaticResource CategoryCardTemplate}">
                            <ItemsRepeater.Layout>
                                <FlowLayout Orientation="Horizontal" MinColumnSpacing="8" MinRowSpacing="8" />
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Actions Section -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Actions" FontSize="16" FontWeight="SemiBold" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button
                                Content="Organize"
                                Command="{x:Bind ViewModel.OrganizeFilesCommand}"
                                IsEnabled="{x:Bind ViewModel.IsFolderSelected, Mode=OneWay}"
                                Height="44"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                Grid.Column="1"
                                Content="Rename"
                                Click="OnRenameClick"
                                IsEnabled="{x:Bind ViewModel.IsFolderSelected, Mode=OneWay}"
                                Height="44"
                                Style="{StaticResource AccentButtonStyle}" />
                        </Grid>

                        <Button
                            Content="Undo Last Operation"
                            Command="{x:Bind ViewModel.UndoCommand}"
                            IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}"
                            Height="40"
                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- Activity Log -->
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="20,16">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Activity Log" FontSize="16" FontWeight="SemiBold" />
                            <ProgressRing
                                Grid.Column="1"
                                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                Width="16"
                                Height="16"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                        </Grid>
                        <ListView
                            ItemsSource="{x:Bind ViewModel.ActivityLog, Mode=OneWay}"
                            MaxHeight="200"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectionMode="None"
                            IsHitTestVisible="False">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="4,2" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <TextBlock
                    Text="Made with ❤️ for Windows 11"
                    FontSize="12"
                    Opacity="0.4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
